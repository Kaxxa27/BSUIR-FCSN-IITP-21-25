[ 485]    0524:                                       Print_Number_Proc PROC near
[ 486]        :                                       
[ 487]    0524: B9 00 00                              mov cx,0h ; Количество цифр у числа
[ 488]        :                                       
[ 489]        :                                       ; Добавление цифр в тек
[ 490]    0527:                                       pushDigitsWhile:
[ 491]    0527: BA 00 00                              mov dx,0h
[ 492]    052A: A1 26 07                              mov ax,Number_General ; AX = число
[ 493]    052D: F7 36 38 07                           div ten              ; DX:AX / ten = DX:AX
[ 494]        :                                       
[ 495]    0531: A3 26 07                              mov Number_General,ax ; numberGeneral уже /= 10
[ 496]        :                                       
[ 497]    0534: 83 C2 30                              add dx,48d ; DX += 48 (перевод в ASCII)
[ 498]    0537: 52                                    push dx ; DX = текущая цифра числа
[ 499]        :                                       
[ 500]    0538: 41                                    inc cx ; CX ++
[ 501]        :                                       
[ 502]        :                                       ; Условие выхода из цикла
[ 503]    0539: 83 3E 26 07 00                        cmp Number_General,0h
[ 504]    053E: 75 E7                                 jne pushDigitsWhile
[ 505]        :                                       
[ 506]        :                                       ; Доставание из стека и печать цифр
[ 507]    0540:                                       printDigitsWhile:
[ 508]    0540: BA 00 00                              mov dx,0h
[ 509]    0543: A1 26 07                              mov ax,Number_General ; AX = число
[ 510]    0546: F7 36 38 07                           div ten              ; DX:AX / ten = DX:AX
[ 511]        :                                       
[ 512]    054A: A3 26 07                              mov Number_General,ax ; numberGeneral уже /= 10
[ 513]        :                                       
[ 514]        :                                       ; Цифра числа DX
[ 515]        :                                       ; прерывание берет ASCII символа из DL
[ 516]    054D: 5A                                    pop dx
[ 517]    054E: B4 06                                 mov ah,06h
[ 518]    0550: CD 21                                 int 21h
[ 519]        :                                       
[ 520]        :                                       
[ 521]        :                                       ; Условие выхода из цикла
[ 522]    0552: 49                                    dec cx
[ 523]    0553: 83 F9 00                              cmp cx,0h
[ 524]    0556: 75 E8                                 jne printDigitsWhile
[ 525]        :                                       
[ 526]    0558: C3                                    ret
[ 527]        :                                       
[ 528]        :                                       Print_Number_Proc endp
