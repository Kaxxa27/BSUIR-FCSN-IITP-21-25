[ 503]    0572: F7 36 43 07                           div ten              ; DX:AX / ten = DX:AX
[ 504]        :                                       
[ 505]    0576: A3 31 07                              mov Number_General,ax ; numberGeneral уже /= 10
[ 506]        :                                       
[ 507]        :                                       ; ÷ифра числа DX
[ 508]        :                                       ; прерывание берет ASCII символа из DL
[ 509]    0579: 5A                                    pop dx
[ 510]    057A: B4 06                                 mov ah,06h
[ 511]    057C: CD 21                                 int 21h
[ 512]        :                                       
[ 513]        :                                       
[ 514]        :                                       ; ”словие выхода из цикла
[ 515]    057E: 49                                    dec cx
[ 516]    057F: 83 F9 00                              cmp cx,0h
[ 517]    0582: 75 E8                                 jne printDigitsWhile
[ 518]        :                                       
[ 519]    0584: C3                                    ret
