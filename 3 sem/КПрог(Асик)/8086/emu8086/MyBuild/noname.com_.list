[ 478]    0550:                                       Print_Number_Proc PROC near
[ 479]        :                                       
[ 480]    0550: B9 00 00                              mov cx,0h ;  оличество цифр у числа
[ 481]        :                                       
[ 482]        :                                       ; ƒобавление цифр в тек
[ 483]    0553:                                       pushDigitsWhile:
[ 484]    0553: BA 00 00                              mov dx,0h
[ 485]    0556: A1 31 07                              mov ax,Number_General ; AX = число
[ 486]    0559: F7 36 43 07                           div ten              ; DX:AX / ten = DX:AX
[ 487]        :                                       
[ 488]    055D: A3 31 07                              mov Number_General,ax ; numberGeneral уже /= 10
[ 489]        :                                       
[ 490]    0560: 83 C2 30                              add dx,48d ; DX += 48 (перевод в ASCII)
[ 491]    0563: 52                                    push dx ; DX = текуща€ цифра числа
[ 492]        :                                       
[ 493]    0564: 41                                    inc cx ; CX ++
[ 494]        :                                       
[ 495]        :                                       ; ”словие выхода из цикла
[ 496]    0565: 83 3E 31 07 00                        cmp Number_General,0h
[ 497]    056A: 75 E7                                 jne pushDigitsWhile
[ 498]        :                                       
